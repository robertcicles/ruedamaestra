---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import StrategyCard from "../components/StrategyCard.astro";
import ResponsibleGamingNotice from "../components/ResponsibleGamingNotice.astro";
---
<BaseLayout title="RuedaMaestra" description="Simulador de ruleta europea educativa con estrategias y saldo ficticio." url="/">
  <Hero />

  <section class="home-section">
    <div class="home-grid">
      <article class="feature-card">
        <h2>Qué es RuedaMaestra</h2>
        <p>RuedaMaestra es una plataforma educativa para practicar con una ruleta europea interactiva, analizar sistemas de apuesta y comprender el riesgo antes de jugar.</p>
      </article>

      <article class="feature-card">
        <h2>Qué puedes hacer</h2>
        <ul>
          <li>Colocar fichas en una mesa realista.</li>
          <li>Probar múltiples tipos de apuesta y estrategias.</li>
          <li>Usar saldo ficticio sin riesgo real.</li>
          <li>Ver resultados, historial y rendimiento.</li>
        </ul>
      </article>
    </div>

    <section class="strategies-preview">
      <h2>Estrategias populares</h2>
      <div class="strategy-grid">
        <StrategyCard title="Martingala" description="Aumenta la apuesta tras cada pérdida para recuperar pérdidas con una ganancia mínima." difficulty="Media" risk="Alto" />
        <StrategyCard title="Fibonacci" description="Usa la secuencia de Fibonacci para ajustar apuestas con pérdidas y ganancias." difficulty="Media" risk="Moderado" />
        <StrategyCard title="D’Alembert" description="Incrementos y decrementos suaves de apuesta para controlar la volatilidad." difficulty="Baja" risk="Moderado" />
        <StrategyCard title="Labouchere" description="Crea una tabla de números y elimina extremos con cada ganancia." difficulty="Alta" risk="Alto" />
      </div>
    </section>

    <ResponsibleGamingNotice />

    <section class="home-cta">
      <h2>Accede al simulador</h2>
      <p>Empieza a practicar con apuestas ficticias y comprueba cómo funciona la ruleta europea antes de invertir tiempo en estrategias.</p>
      <a class="button primary" href="/simulador-ruleta-europea/">Abrir simulador</a>
    </section>
  </section>
</BaseLayout>
